PORT=4000
CLIENT_URL=http://localhost:8080
MONGODB_URI=mongodb://127.0.0.1:27017/proximo
REDIS_URL=redis://127.0.0.1:6379

# Public server URL used for upload links returned to the app.
PUBLIC_BASE_URL=https://proximo.pushvault.shop

# Optional custom upload directory on the VPS.
# If omitted, uploads will be stored in ./uploads relative to the server root.
UPLOAD_DIR=/root/dating-app-server/uploads

# Google Sign-In backend token verification.
GOOGLE_CLIENT_ID=

# OTP provider configuration.
OTP_PROVIDER=ADVANTA
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MESSAGE_TEMPLATE=Your Proximo verification code is {{code}}. It expires in {{minutes}} minutes.

# Advanta SMS credentials.
ADVANTA_BASE_URL=https://quicksms.advantasms.com
ADVANTA_API_KEY=
ADVANTA_PARTNER_ID=
ADVANTA_SHORTCODE=
